# ============================================
# Frontend Environment Variables (Vite)
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
#
# Vite выставляет в браузер ТОЛЬКО переменные с префиксом VITE_
# Никогда не клади сюда секреты бэкенда!
# ============================================

# URL бэкенд-API (без /api на конце)
VITE_API_BASE=https://your-domain.com

# WebSocket URL для уведомлений
VITE_WS_URL=ws://localhost:3000
