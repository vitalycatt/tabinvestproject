# ============================================
# Backend Environment Variables
# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
# ============================================

# --- Обязательные (без них сервер не запустится) ---
TELEGRAM_BOT_TOKEN=
MONGODB_URI=
WEBAPP_URL=https://your-domain.com

# --- Сервер ---
PORT=3000
API_URL=https://your-domain.com/api
APP_URL=https://your-domain.com

# --- Загрузка файлов (только production) ---
UPLOAD_DIR=/var/www/your-domain/frontend/uploads

# --- Админка (в production обязательно сменить!) ---
ADMIN_LOGIN=admin
ADMIN_PASSWORD=admin
JWT_SECRET=change-me-to-random-string

# --- Опциональные ---
# ADMIN_TELEGRAM_ID=123456789
# PASSIVE_INCOME_CRON=0 */6 * * *
# API_KEY=your-api-key
# NODE_ENV=production
